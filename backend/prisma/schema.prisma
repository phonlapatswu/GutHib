generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id       Int             @id @default(autoincrement())
  username      String          @unique @db.VarChar(50)
  password_hash String
  email         String          @unique @db.VarChar(255)
  role          user_role       @default(Worker)
  avatar_url    String?         @db.VarChar(500)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  commits       CommitLog[]
  projects      Project[]
  submissions   Submission[]
  sent_messages     Message[]      @relation("SentMessages")
  received_messages Message[]      @relation("ReceivedMessages")
  memberships   ProjectMember[]
  comments      TaskComment[]
  task_assignments TaskAssignee[]
  project_read_receipts ProjectReadReceipt[]

  @@map("users")
}

model Project {
  project_id  Int             @id @default(autoincrement())
  owner_id    Int
  title       String          @db.VarChar(255)
  description String?
  status      project_status  @default(Active)
  end_date    DateTime?       @db.Date
  created_at  DateTime        @default(now()) @db.Timestamptz(6)
  owner       User            @relation(fields: [owner_id], references: [user_id], onUpdate: NoAction)
  tasks       Task[]
  members     ProjectMember[]
  messages    Message[]
  read_receipts ProjectReadReceipt[]

  @@index([owner_id], map: "idx_projects_owner")
  @@index([status], map: "idx_projects_status")
  @@map("projects")
}

model Task {
  task_id        Int           @id @default(autoincrement())
  project_id     Int
  parent_task_id Int?
  title          String        @db.VarChar(255)
  description    String?
  priority       task_priority @default(Medium)
  status         task_status   @default(Open)
  due_date       DateTime?       @db.Date
  planned_start_date DateTime?     @db.Date
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  started_at     DateTime?       @db.Timestamptz(6)
  completed_at   DateTime?       @db.Timestamptz(6)
  merged_at      DateTime?       @db.Timestamptz(6)
  commits        CommitLog[]
  submissions    Submission[]
  comments       TaskComment[]
  parent_task    Task?           @relation("TaskToTask", fields: [parent_task_id], references: [task_id], onUpdate: NoAction)
  sub_tasks      Task[]          @relation("TaskToTask")
  project        Project         @relation(fields: [project_id], references: [project_id], onDelete: Cascade, onUpdate: NoAction)
  assignees      TaskAssignee[]

  @@index([parent_task_id], map: "idx_tasks_parent")
  @@index([priority], map: "idx_tasks_priority")
  @@index([project_id], map: "idx_tasks_project")
  @@index([status], map: "idx_tasks_status")
  @@index([planned_start_date], map: "idx_tasks_start")
  @@index([due_date], map: "idx_tasks_due")
  @@map("tasks")
}

model TaskAssignee {
  id       Int  @id @default(autoincrement())
  task_id  Int
  user_id  Int
  task     Task @relation(fields: [task_id], references: [task_id], onDelete: Cascade)
  user     User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([task_id, user_id])
  @@map("task_assignees")
}

model CommitLog {
  log_id    Int        @id @default(autoincrement())
  task_id   Int
  user_id   Int
  action    log_action
  message   String?
  timestamp DateTime   @default(now()) @db.Timestamptz(6)
  task      Task       @relation(fields: [task_id], references: [task_id], onDelete: Cascade, onUpdate: NoAction)
  user      User       @relation(fields: [user_id], references: [user_id], onUpdate: NoAction)

  @@index([task_id], map: "idx_logs_task")
  @@index([timestamp(sort: Desc)], map: "idx_logs_timestamp")
  @@index([user_id], map: "idx_logs_user")
  @@map("commit_logs")
}

model Submission {
  submission_id Int      @id @default(autoincrement())
  task_id       Int
  worker_id     Int
  content       String?
  file_url      String?
  submitted_at  DateTime @default(now()) @db.Timestamptz(6)
  task          Task     @relation(fields: [task_id], references: [task_id], onDelete: Cascade, onUpdate: NoAction)
  worker        User     @relation(fields: [worker_id], references: [user_id], onUpdate: NoAction)

  @@index([task_id], map: "idx_submissions_task")
  @@index([worker_id], map: "idx_submissions_worker")
  @@map("submissions")
}

enum log_action {
  Claim
  Submit
  Request_Changes @map("Request Changes")
  Merge
}

enum project_status {
  Active
  Archived
}

enum task_priority {
  High
  Medium
  Low
}

enum task_status {
  Open
  In_Progress @map("In Progress")
  Review
  Closed
}

enum user_role {
  Requester
  Worker
  Manager
  Admin
}


model Message {
  message_id   Int      @id @default(autoincrement())
  sender_id    Int
  recipient_id Int?
  project_id   Int?
  text         String   @db.Text
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  read_at      DateTime? @db.Timestamptz(6)
  sender       User     @relation("SentMessages", fields: [sender_id], references: [user_id], onDelete: Cascade)
  recipient    User?    @relation("ReceivedMessages", fields: [recipient_id], references: [user_id], onDelete: SetNull)
  project      Project? @relation(fields: [project_id], references: [project_id], onDelete: Cascade)

  @@index([sender_id])
  @@index([recipient_id])
  @@index([project_id])
  @@index([created_at(sort: Desc)])
  @@map("messages")
}

model ProjectMember {
  id         Int      @id @default(autoincrement())
  project_id Int
  user_id    Int
  joined_at  DateTime @default(now()) @db.Timestamptz(6)
  project    Project  @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@map("project_members")
}

model TaskComment {
  comment_id Int      @id @default(autoincrement())
  task_id    Int
  author_id  Int
  content    String   @db.Text
  file_url   String?  @db.VarChar(500)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  task       Task     @relation(fields: [task_id], references: [task_id], onDelete: Cascade)
  author     User     @relation(fields: [author_id], references: [user_id], onDelete: Cascade)

  @@index([task_id])
  @@index([created_at(sort: Desc)])
  @@map("task_comments")
}

model ProjectReadReceipt {
  id           Int      @id @default(autoincrement())
  project_id   Int
  user_id      Int
  last_read_at DateTime @default(now()) @db.Timestamptz(6)
  project      Project  @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  user         User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@map("project_read_receipts")
}
